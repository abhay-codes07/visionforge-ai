{
  "name": "visionary-agent-protocol",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "dev:frontend": "npm --workspace frontend run dev",
    "build:frontend": "npm --workspace frontend run build",
    "start:frontend": "npm --workspace frontend run start",
    "lint:frontend": "npm --workspace frontend run lint",
    "test:frontend": "npm --workspace frontend run test",
    "dev:backend": "uvicorn app.main:app --reload --host 0.0.0.0 --port 8000 --app-dir backend",
    "test:backend": "pytest backend/tests",
    "up": "docker compose -f docker/docker-compose.yml up -d --build",
    "down": "docker compose -f docker/docker-compose.yml down",
    "logs": "docker compose -f docker/docker-compose.yml logs -f",
    "smoke": "powershell -ExecutionPolicy Bypass -File scripts/smoke.ps1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
